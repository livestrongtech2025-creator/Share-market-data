# ============================================================
# NSE Market Analytics Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# ---- Application ----
NODE_ENV=production
APP_PORT=3001
APP_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=NSE Market Analytics

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nse_market
POSTGRES_USER=nse_user
POSTGRES_PASSWORD=nse_secure_pass_2024
DATABASE_URL=postgresql://nse_user:nse_secure_pass_2024@postgres:5432/nse_market

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass_2024

# ---- JWT ----
JWT_SECRET=change_this_jwt_secret_to_something_very_long_and_random
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- AI / LLM ----
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
GEMINI_API_KEY=your-gemini-key-here
AI_MODEL=gpt-4o-mini
AI_SERVICE_URL=http://ai-service:8000

# ---- Notifications ----
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=NSE Analytics <noreply@nseanalytics.com>

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# ---- NSE Scraper ----
NSE_REQUEST_TIMEOUT=30000
NSE_RETRY_ATTEMPTS=3
NSE_RETRY_DELAY=5000
NSE_RATE_LIMIT_RPM=10

# ---- Scheduler ----
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_CRON=30 18 * * 1-5

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs

# ---- Rate Limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100
